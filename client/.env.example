# Rename to .env and set these (Vite only exposes VITE_* to the client).
# For production build, set VITE_SERVER_URI to your API URL.

# VITE_SERVER_URI=https://your-api.example.com
# VITE_SOCKET_URI=http://localhost:7777  # Override if socket won't connect
# VITE_CONTENTFUL_SPACE_ID=
# VITE_CONTENTFUL_ACCESS_TOKEN=
# VITE_CHAIN_ID=1
